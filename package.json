{
  "name": "sans-plan-examiner",
  "version": "1.0.0",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node src/server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src/"
  },
  "jest": {
    "testEnvironment": "node",
    "coveragePathIgnorePatterns": [
